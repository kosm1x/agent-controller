{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Tool Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "colorMode": "value"
      },
      "title": "Total Tool Calls (rolling window)",
      "type": "stat",
      "targets": [
        {
          "expr": "mc_tool_calls_total{tool=\"_total\"}",
          "legendFormat": "Total calls"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 1 },
      "id": 2,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean", "max"]
        }
      },
      "title": "Tool Latency (avg ms, top 10)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "topk(10, mc_tool_latency_avg_ms)",
          "legendFormat": "{{tool}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Runner Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "title": "Runner Success Rate (7d)",
      "type": "gauge",
      "targets": [
        { "expr": "mc_tasks_success_rate", "legendFormat": "{{runner}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 10 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto"
      },
      "title": "Runner Avg Duration (7d)",
      "type": "stat",
      "targets": [
        { "expr": "mc_tasks_duration_avg_ms", "legendFormat": "{{runner}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 20 } }
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 10 },
      "id": 5,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "Active Tasks by Runner",
      "type": "timeseries",
      "targets": [
        { "expr": "mc_tasks_active_by_runner", "legendFormat": "{{runner}}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 102,
      "title": "Task Outcomes",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 18 },
      "id": 6,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "auto"
      },
      "title": "Tasks by Status (all time)",
      "type": "stat",
      "targets": [
        { "expr": "mc_tasks_completed_total", "legendFormat": "{{status}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 18 },
      "id": 7,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean"]
        }
      },
      "title": "Provider Latency (avg vs p95)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "mc_provider_latency_avg_ms",
          "legendFormat": "{{provider}} avg"
        },
        {
          "expr": "mc_provider_latency_p95_ms",
          "legendFormat": "{{provider}} p95"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["agent", "quality", "tools"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Agent Quality",
  "uid": "agent-quality"
}
