      "type": "timeseries",
      "targets": [
        {
          "expr": "avg(rate(node_cpu_seconds_total{mode=\"steal\"}[5m])) * 100",
          "legendFormat": "Steal %"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
