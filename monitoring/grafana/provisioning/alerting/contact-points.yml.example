apiVersion: 1

contactPoints:
  - orgId: 1
    name: telegram-jarvis
    receivers:
      - uid: telegram-jarvis-1
        type: telegram
        settings:
          bottoken: "YOUR_TELEGRAM_BOT_TOKEN"
          chatid: "YOUR_TELEGRAM_CHAT_ID"
          parse_mode: HTML
          disable_web_page_preview: true
          message: |
            {{ if eq .Status "firing" }}🔴{{ else }}🟢{{ end }} <b>{{ .Status | toUpper }}</b>
            {{ range .Alerts }}
            <b>{{ .Labels.alertname }}</b> [{{ .Labels.severity }}]
            {{ .Annotations.summary }}
            {{ .Annotations.description }}
            {{ end }}
