# Mission Control — Environment Variables
# Copy to .env and fill in values

# --- Required ---
MC_API_KEY=your-api-key-here
INFERENCE_PRIMARY_URL=https://api.openai.com/v1
INFERENCE_PRIMARY_KEY=sk-...
INFERENCE_PRIMARY_MODEL=gpt-4o-mini

# --- Optional: Direct fallback provider ---
# INFERENCE_FALLBACK_URL=https://api.anthropic.com/v1
# INFERENCE_FALLBACK_KEY=sk-ant-...
# INFERENCE_FALLBACK_MODEL=claude-sonnet-4-20250514

# --- Inference tuning ---
# INFERENCE_TIMEOUT_MS=30000
# INFERENCE_MAX_TOKENS=4096
# INFERENCE_MAX_RETRIES=3          # Set to 1 when behind LiteLLM
# INFERENCE_CONTEXT_LIMIT=128000
# COMPRESSION_THRESHOLD=0.85

# --- Orchestration ---
# ORCHESTRATOR_TIMEOUT_MS=600000
# ORCHESTRATOR_MAX_ITERATIONS=90
# GOAL_TIMEOUT_MS=120000

# --- Server ---
# MC_PORT=8080
# MC_DB_PATH=./data/mc.db

# --- Containers ---
# NANOCLAW_IMAGE=nanoclaw-agent:latest
# MAX_CONCURRENT_CONTAINERS=5

# --- MCP / A2A ---
# MC_MCP_CONFIG=./mcp-servers.json
# A2A_AGENT_NAME=mission-control
# A2A_AGENT_URL=http://localhost:8080

# --- Rituals (daily briefing / nightly close) ---
# RITUALS_ENABLED=false
# RITUALS_TIMEZONE=America/Mexico_City

# --- Email channel (multi-mailbox: IMAP poll + SMTP send, owner-only) ---
# One mailbox per account id. EMAIL_ACCOUNTS is a comma list of ids (each
# [a-z0-9_]+); every id ID gets its own EMAIL_<ID>_* block. Each account is a
# distinct channel (email:<id>) so Jarvis replies from the mailbox the message
# arrived on. Required per account: IMAP_HOST, SMTP_HOST, USERNAME, PASSWORD,
# OWNER_ADDRESS. Optional: IMAP_PORT (993), SMTP_PORT (465), ADDRESS
# (defaults to USERNAME), POLL_INTERVAL_MS (60000).
# EMAIL_ENABLED=false
# EMAIL_ACCOUNTS=comunidades,proyecto2
#
# EMAIL_COMUNIDADES_IMAP_HOST=imap.hostinger.com
# EMAIL_COMUNIDADES_SMTP_HOST=smtp.hostinger.com
# EMAIL_COMUNIDADES_USERNAME=comunidades@mexiconecesario.org.mx
# EMAIL_COMUNIDADES_PASSWORD=app-password-here   # provider app password — keep secret
# EMAIL_COMUNIDADES_ADDRESS=comunidades@mexiconecesario.org.mx
# EMAIL_COMUNIDADES_OWNER_ADDRESS=owner@example.com  # only mail from here is processed
# EMAIL_COMUNIDADES_IMAP_PORT=993
# EMAIL_COMUNIDADES_SMTP_PORT=465
# EMAIL_COMUNIDADES_POLL_INTERVAL_MS=60000
#
# EMAIL_PROYECTO2_IMAP_HOST=imap.hostinger.com
# EMAIL_PROYECTO2_SMTP_HOST=smtp.hostinger.com
# EMAIL_PROYECTO2_USERNAME=proyecto2@example.com
# EMAIL_PROYECTO2_PASSWORD=app-password-here
# EMAIL_PROYECTO2_OWNER_ADDRESS=owner@example.com

# --- Hindsight memory (docker compose --profile hindsight up -d) ---
# HINDSIGHT_ENABLED=false
# HINDSIGHT_URL=http://localhost:8888
# HINDSIGHT_API_KEY=
# HINDSIGHT_PORT=8888
# HINDSIGHT_UI_PORT=9999
# HINDSIGHT_LLM_API_KEY=             # Falls back to INFERENCE_PRIMARY_KEY
# HINDSIGHT_LLM_MODEL=gpt-4o-mini
# HINDSIGHT_LLM_BASE_URL=            # Override for LiteLLM proxy, etc.

# --- LiteLLM sidecar (docker compose --profile litellm up -d) ---
# When using LiteLLM, override the inference vars above:
# INFERENCE_PRIMARY_URL=http://litellm:4000/v1
# INFERENCE_PRIMARY_KEY=sk-litellm-dev
# INFERENCE_PRIMARY_MODEL=default
# INFERENCE_MAX_RETRIES=1
# LITELLM_MASTER_KEY=sk-litellm-dev
# LITELLM_PORT=4000
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
