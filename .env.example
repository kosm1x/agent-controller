# Mission Control - Environment Configuration

# Authentication
MC_API_KEY=change-me-in-production

# Server
MC_PORT=8080
MC_DB_PATH=./data/mc.db

# Primary inference provider (required)
INFERENCE_PRIMARY_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
INFERENCE_PRIMARY_KEY=sk-your-key-here
INFERENCE_PRIMARY_MODEL=qwen3-235b-a22b

# Fallback inference provider (optional)
# INFERENCE_FALLBACK_URL=https://api.minimax.chat/v1
# INFERENCE_FALLBACK_KEY=your-fallback-key
# INFERENCE_FALLBACK_MODEL=MiniMax-M1

# Inference settings
INFERENCE_TIMEOUT_MS=30000
INFERENCE_MAX_TOKENS=4096

# Container settings
NANOCLAW_IMAGE=nanoclaw-agent:latest
MAX_CONCURRENT_CONTAINERS=5
