##
## NanoClaw Coding Sandbox
## Jarvis's isolated coding environment for multi-file implementations and test runs.
##
## Build: docker build -f Dockerfile.nanoclaw -t nanoclaw-coding:latest .
## Usage: Spawned by nanoclaw-runner with workspace volume mount.
##

FROM node:22-slim

# System tools: git, gh CLI, curl
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates && \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
    apt-get update && apt-get install -y gh && \
    rm -rf /var/lib/apt/lists/*

# Global dev tools
RUN npm install -g typescript

WORKDIR /workspace

# Default: interactive shell (overridden by nanoclaw-runner command)
CMD ["node"]
