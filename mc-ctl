shift 2>/dev/null || true

case "$cmd" in
  status)            cmd_status ;;
  start)             cmd_start ;;
  stop)              cmd_stop ;;
  restart)           cmd_restart ;;
  logs)              cmd_logs "$@" ;;
  follow)            cmd_follow ;;

  tasks)             cmd_tasks "$@" ;;
  task)              cmd_task "${1:-}" ;;
  cancel)            cmd_cancel "${1:-}" ;;

  outcomes)          cmd_outcomes "$@" ;;
  reactions)         cmd_reactions ;;

  schedules)         cmd_schedules ;;
  schedule-delete)   cmd_schedule_delete "${1:-}" ;;

  tools)             cmd_tools ;;
  tool-health)       cmd_tool_health ;;

  conversations)     cmd_conversations "${1:-}" ;;
  memory)            cmd_memory ;;

  hindsight-status)  cmd_hindsight_status ;;
  hindsight-restart) cmd_hindsight_restart ;;
  hindsight-logs)    cmd_hindsight_logs "$@" ;;

  recall-utility)    cmd_recall_utility "${1:-24h}" ;;

  budget)            cmd_budget ;;

  tuning)            cmd_tuning "$@" ;;

  intel)             cmd_intel "$@" ;;

  monitoring)        cmd_monitoring "$@" ;;

  tool-chains)       cmd_tool_chains "${1:-7}" ;;

  db)                cmd_db "$@" ;;
  stats)             cmd_stats ;;

  validation)        cmd_validation "$@" ;;

  mcp-token)         cmd_mcp_token "$@" ;;

  help|--help|-h)    usage ;;
