# ---------------------------------------------------------------------------
# Schedules
# ---------------------------------------------------------------------------

cmd_schedules() {
  need_db
  echo -e "${BOLD}=== Active Schedules ===${NC}"
  echo ""
  sql "SELECT schedule_id, name, cron_expr, delivery, active,
    last_run_at, created_at
  FROM scheduled_tasks
  WHERE active = 1
  ORDER BY created_at;" 2>/dev/null || echo -e "${DIM}No scheduled_tasks table yet.${NC}"
}

cmd_schedule_delete() {
  local id="$1"
  [ -n "$id" ] || die "Usage: mc-ctl schedule-delete <schedule_id>"

  # Queue #233 S4-B3-R2: guard ${id} before SQL interpolation. Schedule
  # ids are UUIDs (crypto.randomUUID); guard mirrors cmd_cancel's shape
  # and blocks injection in the sql_raw DELETE below.
  if [[ ! "$id" =~ ^[a-zA-Z0-9_-]{4,64}$ ]]; then
    die "Invalid schedule_id format: '${id}' (expected alphanumeric+dash+underscore, 4-64 chars)"
  fi

  need_db
  local changes
  changes=$(sql_raw "DELETE FROM scheduled_tasks WHERE schedule_id = '${id}'; SELECT changes();" 2>/dev/null)
  if [ "$changes" = "1" ]; then
    echo -e "${GREEN}Schedule ${id} deleted.${NC}"
  else
    die "Schedule ${id} not found."
  fi
}

