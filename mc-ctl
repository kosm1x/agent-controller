#!/usr/bin/env bash
# mc-ctl — Mission Control admin CLI
set -euo pipefail

PROJECT_DIR="/root/claude/mission-control"
SERVICE_NAME="mission-control"
DB_PATH="${PROJECT_DIR}/data/mc.db"
API_URL="${API_URL:-http://localhost:8080}"
HINDSIGHT_URL="http://localhost:8888"
HINDSIGHT_CONTAINER="crm-hindsight"
LOG_LINES=50

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

die() { echo -e "${RED}Error:${NC} $*" >&2; exit 1; }

need_db() {
  [ -f "$DB_PATH" ] || die "Database not found: ${DB_PATH}"
}

sql() {
  sqlite3 -header -column "$DB_PATH" "$1"
}

sql_raw() {
  sqlite3 "$DB_PATH" "$1"
}

api_key() {
  local env_file="${PROJECT_DIR}/.env"
  [ -f "$env_file" ] || die ".env not found"
  grep -oP '(?<=MC_API_KEY=).*' "$env_file" | tr -d '"' | tr -d "'"
}

# Extract a single value from .env WITHOUT sourcing it. Sourcing .env under
# this script's `set -u` aborts on any value containing a `$N` token, and
# would also mangle values with `$`. Non-fatal: prints empty if .env or the
# key is absent (callers degrade gracefully). Mirrors api_key()'s grep style.
env_value() {
  local key="$1" env_file="${PROJECT_DIR}/.env"
  [ -f "$env_file" ] || return 0
  grep -oP "(?<=^${key}=).*" "$env_file" 2>/dev/null | head -1 | tr -d '"' | tr -d "'"
}

api() {
  local method="$1" path="$2"
  shift 2
  local key
  key=$(api_key)
  curl -sf -X "$method" -H "X-Api-Key: ${key}" -H "Content-Type: application/json" \
    "${API_URL}${path}" "$@"
}

color_status() {
  local status="$1"
  case "$status" in
    completed)                echo -e "${GREEN}${status}${NC}" ;;
    running|classifying)      echo -e "${CYAN}${status}${NC}" ;;
    pending|queued)           echo -e "${YELLOW}${status}${NC}" ;;
    failed|cancelled|blocked) echo -e "${RED}${status}${NC}" ;;
    *)                        echo "$status" ;;
  esac
}

# ---------------------------------------------------------------------------
# Service lifecycle
# ---------------------------------------------------------------------------

cmd_status() {
  echo -e "${BOLD}=== Mission Control Status ===${NC}"
  echo ""

  # Service status: check systemd first, then fall back to process detection
  if systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null; then
    echo -e "  Service:    ${GREEN}active${NC} (systemd)"
    local pid
    pid=$(systemctl show -p MainPID --value "$SERVICE_NAME" 2>/dev/null || echo "?")
    echo -e "  PID:        ${pid}"
    local uptime
    uptime=$(systemctl show -p ActiveEnterTimestamp --value "$SERVICE_NAME" 2>/dev/null || echo "?")
    echo -e "  Since:      ${uptime}"
    if [ "$pid" != "?" ] && [ "$pid" != "0" ]; then
      local mem
      mem=$(ps -p "$pid" -o rss= 2>/dev/null || echo "0")
      echo -e "  Memory:     $(( mem / 1024 )) MB"
    fi
  elif pid=$(pgrep -f 'tsx.*src/index\.ts' 2>/dev/null | tail -1) && [ -n "$pid" ]; then
    echo -e "  Service:    ${GREEN}active${NC} (manual tsx, PID ${pid})"
    local mem
    mem=$(ps -p "$pid" -o rss= 2>/dev/null || echo "0")
    echo -e "  Memory:     $(( mem / 1024 )) MB"
    local started
    started=$(ps -p "$pid" -o lstart= 2>/dev/null || echo "?")
    echo -e "  Since:      ${started}"
  else
    echo -e "  Service:    ${RED}inactive${NC}"
  fi

  # API health
  echo ""
  local health
  if health=$(curl -sf --max-time 3 "${API_URL}/health" 2>/dev/null); then
    local api_status db_status inf_status version
    api_status=$(echo "$health" | grep -oP '"status"\s*:\s*"\K[^"]+' || echo "?")
    db_status=$(echo "$health" | grep -oP '"db"\s*:\s*"\K[^"]+' || echo "?")
    inf_status=$(echo "$health" | grep -oP '"inference"\s*:\s*"\K[^"]+' || echo "?")
    version=$(echo "$health" | grep -oP '"version"\s*:\s*"\K[^"]+' || echo "?")
    echo -e "  API:        ${GREEN}reachable${NC} (v${version})"
    echo -e "  DB:         $([ "$db_status" = "ok" ] && echo -e "${GREEN}ok${NC}" || echo -e "${RED}${db_status}${NC}")"
    echo -e "  Inference:  $([ "$inf_status" = "ok" ] && echo -e "${GREEN}ok${NC}" || echo -e "${YELLOW}${inf_status}${NC}")"
  else
    echo -e "  API:        ${RED}unreachable${NC}"
  fi

  # Hindsight
  echo ""
  if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "$HINDSIGHT_CONTAINER"; then
    local hs_health
    if hs_health=$(curl -sf --max-time 3 "${HINDSIGHT_URL}/health" 2>/dev/null); then
      echo -e "  Hindsight:  ${GREEN}healthy${NC}"
    else
      echo -e "  Hindsight:  ${YELLOW}container up, API unhealthy${NC}"
    fi
  else
    echo -e "  Hindsight:  ${DIM}not running${NC}"
  fi

  # DB size
  if [ -f "$DB_PATH" ]; then
    local size
    size=$(du -sh "$DB_PATH" 2>/dev/null | cut -f1)
    echo -e "  DB size:    ${size}"
  fi

  # Key metrics
  if [ -f "$DB_PATH" ]; then
    echo ""
    echo -e "${BOLD}  Quick Metrics${NC}"
    local total running completed failed
    total=$(sql_raw "SELECT COUNT(*) FROM tasks;" 2>/dev/null || echo "0")
    running=$(sql_raw "SELECT COUNT(*) FROM tasks WHERE status = 'running';" 2>/dev/null || echo "0")
    completed=$(sql_raw "SELECT COUNT(*) FROM tasks WHERE status = 'completed';" 2>/dev/null || echo "0")
    failed=$(sql_raw "SELECT COUNT(*) FROM tasks WHERE status = 'failed';" 2>/dev/null || echo "0")
    echo -e "  Tasks:      ${total} total, ${GREEN}${completed}${NC} completed, ${CYAN}${running}${NC} running, ${RED}${failed}${NC} failed"
  fi

  echo ""
}

cmd_start() {
  systemctl start "$SERVICE_NAME"
  sleep 2
  systemctl --no-pager status "$SERVICE_NAME" | head -15
}

cmd_stop() {
  systemctl stop "$SERVICE_NAME"
  echo -e "${GREEN}Service stopped.${NC}"
}

cmd_restart() {
  # `systemctl restart` is async — MainPID can flip within seconds while the
  # OLD pid keeps serving traffic for minutes (see feedback_mc_systemctl_restart_async).
  # Verify newPid != oldPid AND old pid actually dead before declaring success.
  local timeout="${MC_DEPLOY_TIMEOUT_SECS:-300}"  # 2026-05-07 audit W7
  local old_pid new_pid old_dead elapsed=0

  if [[ -f "$DB_PATH" ]]; then
    local running
    running=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM tasks WHERE status='running';" 2>/dev/null || echo "0")
    if [[ "${running:-0}" -gt 0 ]]; then
      echo -e "${YELLOW}WARN${NC}: $running task(s) currently running — restart will kill any in-flight work."
    fi
  fi

  old_pid=$(systemctl show -p MainPID --value "$SERVICE_NAME" 2>/dev/null || echo "0")
  echo "Old MainPID=$old_pid. Restarting..."
  systemctl restart "$SERVICE_NAME"

  new_pid="$old_pid"
  while [[ $elapsed -lt $timeout ]]; do
    sleep 2
    elapsed=$((elapsed + 2))
    new_pid=$(systemctl show -p MainPID --value "$SERVICE_NAME" 2>/dev/null || echo "0")
    old_dead="yes"
    if [[ "$old_pid" != "0" ]] && kill -0 "$old_pid" 2>/dev/null; then
      old_dead="no"
    fi
    if [[ "$new_pid" != "0" && "$new_pid" != "$old_pid" && "$old_dead" == "yes" ]]; then
      break
    fi
    if (( elapsed % 10 == 0 )); then
      echo "  ${elapsed}s — newPid=$new_pid oldDead=$old_dead"
    fi
  done

  if [[ "$new_pid" == "0" || "$new_pid" == "$old_pid" ]] || { [[ "$old_pid" != "0" ]] && kill -0 "$old_pid" 2>/dev/null; }; then
    echo -e "${RED}Restart did not complete cleanly within ${timeout}s.${NC} oldPid=$old_pid newPid=$new_pid"
    return 1
  fi

  echo -e "${GREEN}Restart OK${NC} — newPid=$new_pid (was $old_pid), transition took ${elapsed}s"
  systemctl --no-pager status "$SERVICE_NAME" | head -10
}

cmd_logs() {
  local lines="${1:-$LOG_LINES}"
  journalctl -u "$SERVICE_NAME" --no-pager -n "$lines"
}

cmd_follow() {
  journalctl -fu "$SERVICE_NAME"
}

# ---------------------------------------------------------------------------
# Tasks
# ---------------------------------------------------------------------------

cmd_tasks() {
  need_db
  local status_filter="" limit=20

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status=*) status_filter="${1#--status=}"; shift ;;
      --limit=*)  limit="${1#--limit=}"; shift ;;
      *)          shift ;;
    esac
  done

  local where=""
  if [ -n "$status_filter" ]; then
    where="WHERE status = '${status_filter}'"
  fi

  echo -e "${BOLD}=== Tasks (newest first, limit ${limit}) ===${NC}"
  echo ""
  sql "SELECT task_id, substr(title,1,50) as title, status, agent_type,
    ROUND(CAST(
      (julianday(COALESCE(completed_at, datetime('now'))) - julianday(created_at)) * 86400
    AS REAL), 0) as secs,
    created_at
  FROM tasks ${where}
  ORDER BY created_at DESC LIMIT ${limit};"
}

cmd_task() {
  need_db
  local id="$1"
  [ -n "$id" ] || die "Usage: mc-ctl task <task_id>"

  # Queue #233 S4-B3-R2: guard ${id} before SQL interpolation. Same shape
  # as cmd_cancel — task_ids are UUIDs from crypto.randomUUID; the guard
  # blocks SQL injection in the sql_raw path below.
  if [[ ! "$id" =~ ^[a-zA-Z0-9_-]{4,64}$ ]]; then
    die "Invalid task_id format: '${id}' (expected alphanumeric+dash+underscore, 4-64 chars)"
  fi

  echo -e "${BOLD}=== Task Detail ===${NC}"
  echo ""
  sql "SELECT task_id, title, status, priority, agent_type, classification,
    progress, spawn_type, parent_task_id,
    created_at, started_at, completed_at,
    substr(COALESCE(error,''),1,200) as error
  FROM tasks WHERE task_id = '${id}';"

  echo ""
  echo -e "${BOLD}--- Output ---${NC}"
  sql_raw "SELECT COALESCE(output, '(none)') FROM tasks WHERE task_id = '${id}';" 2>/dev/null

  echo ""
  echo -e "${BOLD}--- Runs ---${NC}"
  sql "SELECT run_id, agent_type, status, phase, duration_ms, created_at
  FROM runs WHERE task_id = '${id}' ORDER BY created_at;"

  echo ""
  echo -e "${BOLD}--- Subtasks ---${NC}"
  sql "SELECT task_id, substr(title,1,40) as title, status, agent_type
  FROM tasks WHERE parent_task_id = '${id}';"
}

cmd_cancel() {
  local id="$1"
  [ -n "$id" ] || die "Usage: mc-ctl cancel <task_id>"

  # Validate id shape before SQL interpolation. Real task_ids are UUIDs
  # (per schema: TEXT UNIQUE NOT NULL, populated via crypto.randomUUID).
  # Allow lowercase hex + dashes + reasonable alphanumeric for legacy ids.
  # This blocks SQL injection in the DB-fallback path below; the API path
  # is parameterized inside Hono.
  if [[ ! "$id" =~ ^[a-zA-Z0-9_-]{4,64}$ ]]; then
    die "Invalid task_id format: '${id}' (expected alphanumeric+dash+underscore, 4-64 chars)"
  fi

  # Fast path: API call with hard 4s timeout. Distinguish:
  #   200  → success
  #   404  → legitimate not-found (don't fall through)
  #   ""   → connection failure or wedged event loop → fall through to DB
  #   other → unexpected, surface as error
  local key body http_code
  key=$(api_key)
  # `|| true` is critical here: under `set -euo pipefail` a curl connect
  # failure (exit 7) or timeout (exit 28) would otherwise abort the script
  # before we can parse the http_code and decide whether to fall back to DB.
  body=$(curl -s --max-time 4 -X POST \
    -H "X-Api-Key: ${key}" -H "Content-Type: application/json" \
    -w '\n__HTTP__%{http_code}__' \
    "${API_URL}/api/tasks/${id}/cancel" 2>/dev/null || true)
  http_code=$(echo "$body" | grep -oE '__HTTP__[0-9]+__' | grep -oE '[0-9]+')
  body=$(echo "$body" | sed 's/__HTTP__[0-9]*__$//')

  case "$http_code" in
    200)
      echo -e "${GREEN}Task ${id} cancelled (via API).${NC}"
      echo "$body" | python3 -m json.tool 2>/dev/null || echo "$body"
      return 0
      ;;
    404)
      die "Task ${id} not found or already in terminal state."
      ;;
    "" | 000)
      # No HTTP response (000) or no body parsed — connection refused or
      # timed out. This is the wedged-event-loop case. Fall through to DB.
      echo -e "${YELLOW}API unreachable (or timed out at 4s) — writing cancel directly to mc.db.${NC}"
      ;;
    *)
      die "API returned unexpected HTTP ${http_code}: ${body}"
      ;;
  esac

  # Fallback path (only reached when API is unreachable/timed-out).
  # Any subprocess already running cannot be interrupted from JS;
  # the runner sees the cancel only at its next loop iteration.
  need_db

  local current_status
  current_status=$(sqlite3 "$DB_PATH" "SELECT status FROM tasks WHERE task_id = '${id}';" 2>/dev/null)
  if [ -z "$current_status" ]; then
    die "Task ${id} not found."
  fi
  case "$current_status" in
    completed | failed | cancelled)
      echo -e "${YELLOW}Task ${id} already in terminal state: ${current_status} (no-op)${NC}"
      return 0
      ;;
  esac

  # Atomic-ish cancel: task + runs in one transaction. Subtasks would need
  # recursive walk; for tonight, one level of cascade.
  sqlite3 "$DB_PATH" <<EOF
BEGIN;
UPDATE tasks SET status = 'cancelled', updated_at = datetime('now'), completed_at = datetime('now') WHERE task_id = '${id}';
UPDATE runs SET status = 'cancelled', completed_at = datetime('now') WHERE task_id = '${id}' AND status = 'running';
UPDATE tasks SET status = 'cancelled', updated_at = datetime('now'), completed_at = datetime('now') WHERE parent_task_id = '${id}' AND status NOT IN ('completed','failed','cancelled');
COMMIT;
EOF
  echo -e "${GREEN}Task ${id} cancelled (direct DB).${NC}"
  echo -e "${YELLOW}Note: any subprocess already running (vitest, gh, etc.) will run to completion;${NC}"
  echo -e "${YELLOW}      the runner sees the cancel at its next loop iteration.${NC}"
}

# ---------------------------------------------------------------------------
# Outcomes
# ---------------------------------------------------------------------------

cmd_outcomes() {
  need_db
  local days=7

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --days=*) days="${1#--days=}"; shift ;;
      *)        shift ;;
    esac
  done

  echo -e "${BOLD}=== Outcome Stats (last ${days} days) ===${NC}"
  echo ""
  echo -e "${BOLD}By Runner:${NC}"
  sql "SELECT ran_on, COUNT(*) as total,
    SUM(success) as ok,
    ROUND(AVG(success)*100, 1) as success_pct,
    ROUND(AVG(duration_ms)) as avg_ms
  FROM task_outcomes
  WHERE created_at >= datetime('now', '-${days} days')
  GROUP BY ran_on
  ORDER BY total DESC;"

  echo ""
  echo -e "${BOLD}By Classification:${NC}"
  sql "SELECT classified_as, COUNT(*) as total,
    SUM(success) as ok,
    ROUND(AVG(success)*100, 1) as success_pct
  FROM task_outcomes
  WHERE created_at >= datetime('now', '-${days} days')
  GROUP BY classified_as
  ORDER BY total DESC
  LIMIT 15;"
}

