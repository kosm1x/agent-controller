# ---------------------------------------------------------------------------
# Monitoring (Prometheus + Grafana)
# ---------------------------------------------------------------------------

cmd_monitoring() {
  local subcmd="${1:-status}"
  local compose_file="${PROJECT_DIR}/docker-compose.monitoring.yml"

  if [ ! -f "$compose_file" ]; then
    echo -e "${RED}Monitoring compose file not found:${NC} $compose_file"
    exit 1
  fi

  case "$subcmd" in
    up)
      echo -e "${CYAN}Starting monitoring stack...${NC}"
      docker compose -f "$compose_file" up -d
      echo ""
      echo -e "${GREEN}Prometheus:${NC} http://localhost:9090"
      echo -e "${GREEN}Grafana:${NC}    http://localhost:3001  (admin / \${GRAFANA_PASSWORD:-jarvis2026})"
      ;;

    down)
      echo -e "${CYAN}Stopping monitoring stack...${NC}"
      docker compose -f "$compose_file" down
      ;;

    status)
      echo -e "${BOLD}Monitoring Stack${NC}"
      echo ""
      docker compose -f "$compose_file" ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || echo "  (not running)"
      echo ""
      # Check Prometheus scrape health
      local health
      health=$(curl -sf http://localhost:9090/api/v1/targets 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); t=d['data']['activeTargets'][0]; print(t['health'])" 2>/dev/null)
      if [ -n "$health" ]; then
        if [ "$health" = "up" ]; then
          echo -e "  Prometheus scrape: ${GREEN}${health}${NC}"
        else
          echo -e "  Prometheus scrape: ${RED}${health}${NC}"
        fi
      else
        echo -e "  Prometheus: ${RED}not reachable${NC}"
      fi
      # Check Grafana
      local gf_health
      gf_health=$(curl -sf http://localhost:3001/api/health 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('database','?'))" 2>/dev/null)
      if [ "$gf_health" = "ok" ]; then
        echo -e "  Grafana:          ${GREEN}ok${NC} (http://localhost:3001)"
      else
        echo -e "  Grafana:          ${RED}not reachable${NC}"
      fi
      ;;

    *)
      echo -e "${RED}Unknown monitoring subcommand:${NC} $subcmd"
      echo "  Usage: mc-ctl monitoring [up|down|status]"
      exit 1
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Self-Tuning
# ---------------------------------------------------------------------------

cmd_tuning() {
  need_db
  local subcmd="${1:-status}"
  shift 2>/dev/null || true

  case "$subcmd" in
    status)
      echo -e "\n${BOLD}TUNING STATUS${NC}\n"
      local row
      row=$(sqlite3 -separator '|' "$DB_PATH" \
        "SELECT run_id, status, baseline_score, best_score, experiments_run, experiments_won, total_cost_usd, started_at, completed_at FROM tune_runs ORDER BY started_at DESC LIMIT 1" 2>/dev/null || echo "")
      if [ -z "$row" ]; then
        echo "No tuning runs found."
        return
      fi
      IFS='|' read -r run_id status baseline best exp_run exp_won cost started completed <<< "$row"
      echo -e "  Run ID:       ${CYAN}${run_id}${NC}"
      echo -e "  Status:       ${status}"
      echo -e "  Baseline:     ${baseline:-N/A}"
      echo -e "  Best Score:   ${GREEN}${best:-N/A}${NC}"
      echo -e "  Experiments:  ${exp_run} run, ${GREEN}${exp_won} wins${NC}"
      echo -e "  Cost:         \$${cost}"
      echo -e "  Started:      ${started}"
      echo -e "  Completed:    ${completed:-running}"
      echo ""

      # Show recent experiments
      echo -e "${BOLD}Recent experiments:${NC}"
      sqlite3 -column -header "$DB_PATH" \
        "SELECT experiment_id, surface, target, status,
                ROUND(baseline_score, 1) as baseline,
                ROUND(mutated_score, 1) as mutated,
                SUBSTR(hypothesis, 1, 60) as hypothesis
         FROM tune_experiments
         WHERE run_id = '${run_id}'
         ORDER BY created_at DESC LIMIT 10" 2>/dev/null || echo "No experiments found."
      echo ""
      ;;

    report)
      local run_id="${1:-}"
      local query
      if [ -n "$run_id" ]; then
        query="SELECT report FROM tune_runs WHERE run_id = '${run_id}'"
      else
        query="SELECT report FROM tune_runs ORDER BY started_at DESC LIMIT 1"
      fi
      local report
      report=$(sqlite3 "$DB_PATH" "$query" 2>/dev/null || echo "")
      if [ -z "$report" ]; then
        echo "No report found."
      else
        echo "$report"
      fi
      ;;

    promote)
      local run_id="${1:-}"
      local query
      if [ -n "$run_id" ]; then
        query="SELECT surface, target, mutation_type, original_value, mutated_value, hypothesis FROM tune_experiments WHERE run_id = '${run_id}' AND status = 'passed' ORDER BY created_at"
      else
        query="SELECT e.surface, e.target, e.mutation_type, e.original_value, e.mutated_value, e.hypothesis FROM tune_experiments e INNER JOIN (SELECT run_id FROM tune_runs ORDER BY started_at DESC LIMIT 1) r ON e.run_id = r.run_id WHERE e.status = 'passed' ORDER BY e.created_at"
      fi

      echo -e "\n${BOLD}WINNING MUTATIONS TO PROMOTE${NC}\n"
      local found=0
      while IFS='|' read -r surface target mtype orig_val mut_val hyp; do
        found=1
        echo -e "${GREEN}─── ${surface}/${target} (${mtype}) ───${NC}"
        echo -e "${DIM}Hypothesis: ${hyp}${NC}"
        echo ""
        echo -e "${RED}--- Original:${NC}"
        echo "$orig_val" | head -10
        echo ""
        echo -e "${GREEN}+++ Mutation:${NC}"
        echo "$mut_val" | head -20
        echo ""
      done < <(sqlite3 -separator '|' "$DB_PATH" "$query" 2>/dev/null)

      if [ "$found" -eq 0 ]; then
        echo "No winning mutations to promote."
      else
        echo -e "${YELLOW}Review the mutations above. Apply manually or via Claude Code.${NC}"
      fi
      echo ""
      ;;

    *)
      echo -e "${RED}Unknown tuning subcommand:${NC} ${subcmd}"
      echo "Usage: mc-ctl tuning [status|report|promote] [run_id]"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Intel commands (S6 Intelligence Depot)
# ---------------------------------------------------------------------------

cmd_intel() {
  need_db
  local subcmd="${1:-status}"
  shift 2>/dev/null || true

  case "$subcmd" in
    status)
      echo -e "${BOLD}=== Intelligence Depot Status ===${NC}"
      echo ""
      echo -e "${BOLD}Snapshots (last poll per source):${NC}"
      sql "SELECT source, key, last_value_numeric, snapshot_at, run_count
        FROM signal_snapshots
        ORDER BY snapshot_at DESC
        LIMIT 30;"
      echo ""
      echo -e "${BOLD}Signal counts (last 24h):${NC}"
      sql "SELECT source, COUNT(*) as signals, MIN(collected_at) as oldest, MAX(collected_at) as newest
        FROM signals
        WHERE collected_at >= datetime('now', '-24 hours')
        GROUP BY source
        ORDER BY signals DESC;"
      ;;
    signals)
      local hours
      hours=$(printf '%d' "${1:-24}" 2>/dev/null) || hours=24
      echo -e "${BOLD}=== Signals (last ${hours}h) ===${NC}"
      sql "SELECT id, source, domain, signal_type, key,
        COALESCE(value_numeric, '') as val_num,
        SUBSTR(COALESCE(value_text, ''), 1, 60) as val_text,
        collected_at
        FROM signals
        WHERE collected_at >= datetime('now', '-${hours} hours')
        ORDER BY collected_at DESC
        LIMIT 50;"
      ;;
    deltas)
      echo -e "${BOLD}=== Active Deltas (from snapshots) ===${NC}"
      echo ""
      echo -e "Showing source+key pairs with recent updates:"
      sql "SELECT s.source, s.key, s.last_value_numeric as current_val,
        s.run_count, s.snapshot_at
        FROM signal_snapshots s
        WHERE s.snapshot_at >= datetime('now', '-1 hours')
        ORDER BY s.snapshot_at DESC
        LIMIT 30;"
      ;;
    counts)
      echo -e "${BOLD}=== Signal Totals ===${NC}"
      sql "SELECT source, COUNT(*) as total,
        SUM(CASE WHEN collected_at >= datetime('now', '-1 hours') THEN 1 ELSE 0 END) as last_1h,
        SUM(CASE WHEN collected_at >= datetime('now', '-24 hours') THEN 1 ELSE 0 END) as last_24h
        FROM signals
        GROUP BY source
        ORDER BY total DESC;"
      ;;
    *)
      echo -e "${RED}Unknown intel subcommand:${NC} ${subcmd}"
      echo "Usage: mc-ctl intel [status|signals [hours]|deltas|counts]"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# V7 Validation Log
# ---------------------------------------------------------------------------

VALIDATION_LOG="${PROJECT_DIR}/data/v7-validation.log"
VALIDATION_START="2026-04-10"

cmd_validation() {
  need_db
  local subcmd="${1:-check}"

  case "$subcmd" in
    check)
      local today
      today=$(date +%Y-%m-%d)
      local day_num
      day_num=$(( ( $(date -d "$today" +%s) - $(date -d "$VALIDATION_START" +%s) ) / 86400 + 1 ))

      echo -e "\n${BOLD}V7 VALIDATION — Day ${day_num}/30${NC} ($today)"
      echo -e "${DIM}Started: ${VALIDATION_START} — Gate: 2026-05-10${NC}\n"

      local pass=0 fail=0 warn=0

      # 1. Service uptime
      local active
      active=$(systemctl is-active "$SERVICE_NAME" 2>/dev/null || echo "inactive")
      if [ "$active" = "active" ]; then
        local uptime_sec
        uptime_sec=$(systemctl show "$SERVICE_NAME" --property=ActiveEnterTimestamp --value 2>/dev/null)
        echo -e "  ${GREEN}[PASS]${NC} Service active (since $uptime_sec)"
        pass=$((pass+1))
      else
        echo -e "  ${RED}[FAIL]${NC} Service not running"
        fail=$((fail+1))
      fi

      # 2. Ritual completion (last 24h)
      local rituals_expected=0 rituals_completed=0
      # Check cron-scheduled rituals from schedule_runs in last 24h
      rituals_expected=$(sql_raw "SELECT COUNT(DISTINCT schedule_id) FROM schedule_runs WHERE spawned_at >= datetime('now', '-24 hours');")
      rituals_completed=$(sql_raw "SELECT COUNT(DISTINCT schedule_id) FROM schedule_runs WHERE spawned_at >= datetime('now', '-24 hours') AND status = 'completed';")
      local rituals_missed=$((rituals_expected - rituals_completed))
      if [ "$rituals_missed" -eq 0 ] && [ "$rituals_expected" -gt 0 ]; then
        echo -e "  ${GREEN}[PASS]${NC} Rituals: ${rituals_completed}/${rituals_expected} completed (24h)"
        pass=$((pass+1))
      elif [ "$rituals_expected" -eq 0 ]; then
        echo -e "  ${YELLOW}[WARN]${NC} No rituals fired in last 24h"
        warn=$((warn+1))
      else
        echo -e "  ${RED}[FAIL]${NC} Rituals: ${rituals_completed}/${rituals_expected} (${rituals_missed} missed)"
        fail=$((fail+1))
      fi

      # 3. Message delivery (last 24h) — tasks from messaging
      local total_msgs completed_msgs delivery_pct
      total_msgs=$(sql_raw "SELECT COUNT(*) FROM tasks WHERE created_at >= datetime('now', '-24 hours');")
      completed_msgs=$(sql_raw "SELECT COUNT(*) FROM tasks WHERE created_at >= datetime('now', '-24 hours') AND status IN ('completed', 'completed_with_concerns');")
      if [ "$total_msgs" -gt 0 ]; then
        delivery_pct=$((completed_msgs * 100 / total_msgs))
        if [ "$delivery_pct" -ge 95 ]; then
          echo -e "  ${GREEN}[PASS]${NC} Task completion: ${delivery_pct}% (${completed_msgs}/${total_msgs})"
          pass=$((pass+1))
        else
          echo -e "  ${RED}[FAIL]${NC} Task completion: ${delivery_pct}% (${completed_msgs}/${total_msgs}) — below 95%"
          fail=$((fail+1))
        fi
      else
        echo -e "  ${YELLOW}[WARN]${NC} No tasks in last 24h"
        warn=$((warn+1))
      fi

      # 4. Hallucination / confirmation gate holds
      local gate_violations
      gate_violations=$(sql_raw "SELECT COUNT(*) FROM events WHERE type = 'confirmation_gate_bypass' AND created_at >= datetime('now', '-24 hours');" 2>/dev/null || echo "0")
      if [ "$gate_violations" -eq 0 ]; then
        echo -e "  ${GREEN}[PASS]${NC} Confirmation gate: no violations (24h)"
        pass=$((pass+1))
      else
        echo -e "  ${RED}[FAIL]${NC} Confirmation gate: ${gate_violations} violations"
        fail=$((fail+1))
      fi

      # 5. Context pressure — emergency compactions
      local compactions
      compactions=$(journalctl -u "$SERVICE_NAME" --since "24 hours ago" --no-pager 2>/dev/null | grep -c -E "emergency.*compact|CONTEXT_PRESSURE_CRITICAL" 2>/dev/null || true)
      compactions="${compactions:-0}"; compactions="${compactions##*$'\n'}"
      if [ "$compactions" -eq 0 ]; then
        echo -e "  ${GREEN}[PASS]${NC} Context pressure: no emergency compactions (24h)"
        pass=$((pass+1))
      else
        echo -e "  ${YELLOW}[WARN]${NC} Emergency compactions: ${compactions} in 24h"
        warn=$((warn+1))
      fi

      # 6. DB size
      local db_size_mb
      db_size_mb=$(du -m "$DB_PATH" 2>/dev/null | cut -f1)
      if [ "$db_size_mb" -lt 400 ]; then
        echo -e "  ${GREEN}[PASS]${NC} DB size: ${db_size_mb}MB (limit: 400MB)"
        pass=$((pass+1))
      else
        echo -e "  ${YELLOW}[WARN]${NC} DB size: ${db_size_mb}MB — approaching limit"
        warn=$((warn+1))
      fi

      # 7. Embedding health
      local embed_count conv_count embed_pct
      embed_count=$(sql_raw "SELECT COUNT(*) FROM conversation_embeddings;")
      conv_count=$(sql_raw "SELECT COUNT(*) FROM conversations;")
      if [ "$conv_count" -gt 0 ]; then
        embed_pct=$((embed_count * 100 / conv_count))
        if [ "$embed_pct" -ge 90 ]; then
          echo -e "  ${GREEN}[PASS]${NC} Embeddings: ${embed_count}/${conv_count} (${embed_pct}%)"
          pass=$((pass+1))
        else
          echo -e "  ${YELLOW}[WARN]${NC} Embeddings: ${embed_count}/${conv_count} (${embed_pct}%) — below 90%"
          warn=$((warn+1))
        fi
      fi

      # 8. Scope classifier — no tool routing errors in logs.
      # Real messaging classifier errors carry the [router] or [classifier]
      # log prefix. The previous regex matched any "scope.*error" which
      # false-positived on Playwright pino logs ($scope=page $level=error,
      # $scope=browser $level=error) emitted when the browser tool rejects
      # unsupported URL schemes. Tightened to require an explicit prefix
      # AND filter out pino's $scope= structured field.
      local scope_errors
      scope_errors=$(journalctl -u "$SERVICE_NAME" --since "24 hours ago" --no-pager 2>/dev/null \
        | grep -v '\$scope=' \
        | grep -c -E '\[(router|classifier|messaging)\].*[Ee]rror|[Cc]lassifier.*[Ff]ailed' 2>/dev/null || true)
      scope_errors="${scope_errors:-0}"; scope_errors="${scope_errors##*$'\n'}"
      if [ "$scope_errors" -eq 0 ]; then
        echo -e "  ${GREEN}[PASS]${NC} Scope classifier: no errors (24h)"
        pass=$((pass+1))
      else
        echo -e "  ${YELLOW}[WARN]${NC} Scope classifier errors: ${scope_errors}"
        warn=$((warn+1))
      fi

      # 9. Poisoned threads
      local poison_events
      poison_events=$(sql_raw "SELECT COUNT(*) FROM events WHERE type LIKE '%poison%' AND created_at >= datetime('now', '-24 hours');" 2>/dev/null || echo "0")
      if [ "$poison_events" -eq 0 ]; then
        echo -e "  ${GREEN}[PASS]${NC} No poisoned thread incidents (24h)"
        pass=$((pass+1))
      else
        echo -e "  ${RED}[FAIL]${NC} Poisoned thread events: ${poison_events}"
        fail=$((fail+1))
      fi

      # 10. Failed tasks
      local failed_24h
      failed_24h=$(sql_raw "SELECT COUNT(*) FROM tasks WHERE created_at >= datetime('now', '-24 hours') AND status = 'failed';")
      if [ "$failed_24h" -le 2 ]; then
        echo -e "  ${GREEN}[PASS]${NC} Failed tasks: ${failed_24h} (24h, threshold: ≤2)"
        pass=$((pass+1))
      else
        echo -e "  ${RED}[FAIL]${NC} Failed tasks: ${failed_24h} (24h)"
        fail=$((fail+1))
      fi

      # Summary
      echo ""
      echo -e "  ${BOLD}Score: ${pass} pass, ${warn} warn, ${fail} fail${NC}"
      if [ "$fail" -eq 0 ]; then
        echo -e "  ${GREEN}Day ${day_num} — CLEAN${NC}"
      else
        echo -e "  ${RED}Day ${day_num} — ${fail} FAILURES — investigate before v7${NC}"
      fi

      # Append to log
      echo "${today}|day${day_num}|pass=${pass}|warn=${warn}|fail=${fail}" >> "$VALIDATION_LOG"
      echo ""
      echo -e "  ${DIM}Logged to ${VALIDATION_LOG}${NC}"
      ;;

    log)
      if [ -f "$VALIDATION_LOG" ]; then
        echo -e "\n${BOLD}V7 Validation History${NC}\n"
        column -t -s'|' "$VALIDATION_LOG"
      else
        echo "No validation log yet. Run: mc-ctl validation check"
      fi
      ;;

    *)
      echo -e "${RED}Unknown validation subcommand:${NC} $subcmd"
      echo "  Usage: mc-ctl validation [check|log]"
      exit 1
      ;;
  esac
}

# ---------------------------------------------------------------------------
# v7.7 — MCP token management (Jarvis MCP Server for Claude Code sessions)
# ---------------------------------------------------------------------------

cmd_mcp_token() {
  need_db
  local subcmd="${1:-}"; shift || true

  case "$subcmd" in
    create)
      # Args: --client <name> [--expires-in-days N]
      local client_name=""
      local expires_in_days=""
      while [ $# -gt 0 ]; do
        case "$1" in
          --client) client_name="$2"; shift 2 ;;
          --expires-in-days) expires_in_days="$2"; shift 2 ;;
          *) echo -e "${RED}Unknown flag:${NC} $1"; exit 1 ;;
        esac
      done
      if [ -z "$client_name" ]; then
        echo -e "${RED}Error:${NC} --client <name> is required"
        echo "  Usage: mc-ctl mcp-token create --client <name> [--expires-in-days N]"
        exit 1
      fi

      # v7.7.1 C1 fix: strict whitelist on client_name. Previously a single
      # sed "s/'/''/g" pass was the only SQLi defense, which relied on
      # sql_raw's transport quirks — a backslash, newline, or unusual
      # whitespace could still break out. Whitelisting to
      # [A-Za-z0-9_.-]{1,64} is the poka-yoke: the name is a label, not
      # arbitrary text, and any real operator client fits this pattern.
      if ! [[ "$client_name" =~ ^[A-Za-z0-9_.-]{1,64}$ ]]; then
        echo -e "${RED}Error:${NC} --client must match ^[A-Za-z0-9_.-]{1,64}\$"
        echo "  (letters, digits, underscore, dot, hyphen; 1-64 chars)"
        exit 1
      fi

      # v7.7.1 W2: validate --expires-in-days if supplied
      if [ -n "$expires_in_days" ]; then
        if ! [[ "$expires_in_days" =~ ^[0-9]+$ ]] || [ "$expires_in_days" -lt 1 ] || [ "$expires_in_days" -gt 3650 ]; then
          echo -e "${RED}Error:${NC} --expires-in-days must be an integer 1-3650"
          exit 1
        fi
      fi

      # Generate a cryptographically random 32-byte token, hex-encoded with a
      # "jrvs_" prefix for identification. SHA-256 hash stored in DB; raw token
      # shown exactly once to stdout, never logged, never retrievable.
      local raw_token
      raw_token="jrvs_$(openssl rand -hex 32)"
      local token_hash
      token_hash=$(printf '%s' "$raw_token" | sha256sum | awk '{print $1}')

      local expires_clause="NULL"
      if [ -n "$expires_in_days" ]; then
        expires_clause="datetime('now', '+${expires_in_days} days')"
      fi

      local insert_result
      insert_result=$(sql_raw "INSERT INTO mcp_tokens (token_hash, client_name, scope, expires_at) VALUES ('$token_hash', '$client_name', 'read_only', $expires_clause) RETURNING id;" 2>&1)
      if [ -z "$insert_result" ] || [[ "$insert_result" == *"Error"* ]]; then
        echo -e "${RED}Failed to create token:${NC} $insert_result"
        exit 1
      fi

      # v7.7.1 W4 fix: cleaner output hygiene. Print the bearer token on
      # its own line without the inline JSON config snippet that operators
      # tend to copy to clipboards/screenshots. The config snippet is now
      # printed with the token placeholder removed — operators paste the
      # token into the headers field manually, which makes accidental
      # sharing less likely.
      echo ""
      echo -e "${BOLD}Jarvis MCP token created${NC}"
      echo -e "  ID:        ${GREEN}${insert_result}${NC}"
      echo -e "  Client:    ${client_name}"
      echo -e "  Scope:     read_only"
      if [ -n "$expires_in_days" ]; then
        echo -e "  Expires:   in ${expires_in_days} days"
      else
        echo -e "  Expires:   never (consider --expires-in-days for rotation)"
      fi
      echo ""
      echo -e "${YELLOW}═══════════════════════════════════════════════════════════${NC}"
      echo -e "${YELLOW}BEARER TOKEN (shown ONCE — save it now, it cannot be retrieved):${NC}"
      echo -e "${YELLOW}═══════════════════════════════════════════════════════════${NC}"
      echo ""
      echo "$raw_token"
      echo ""
      echo -e "${YELLOW}═══════════════════════════════════════════════════════════${NC}"
      echo ""
      echo -e "${DIM}Claude Code MCP config template — paste the token above into headers.Authorization:${NC}"
      echo '  {"mcpServers": {"jarvis": {"type": "http", "url": "http://localhost:'"${MC_PORT:-3030}"'/mcp", "headers": {"Authorization": "Bearer <PASTE_TOKEN_HERE>"}}}}'
      ;;

    list)
      echo -e "\n${BOLD}Jarvis MCP tokens${NC}\n"
      sql_raw "SELECT id, client_name, scope, created_at, COALESCE(last_used_at, '—') AS last_used, COALESCE(expires_at, 'never') AS expires, CASE revoked WHEN 1 THEN 'REVOKED' WHEN 0 THEN (CASE WHEN expires_at IS NOT NULL AND expires_at <= datetime('now') THEN 'EXPIRED' ELSE 'active' END) END AS status FROM mcp_tokens ORDER BY id DESC;"
      ;;

    revoke)
      local id="${1:-}"
      if [ -z "$id" ]; then
        echo -e "${RED}Error:${NC} token id required"
        echo "  Usage: mc-ctl mcp-token revoke <id>"
        exit 1
      fi
      # v7.7.1 m7 fix: strict integer validation. Previously `mc-ctl
      # mcp-token revoke "1 OR 1=1"` would silently revoke every token.
      if ! [[ "$id" =~ ^[0-9]+$ ]]; then
        echo -e "${RED}Error:${NC} token id must be a positive integer"
        exit 1
      fi
      sql_raw "UPDATE mcp_tokens SET revoked = 1 WHERE id = $id;"
      echo -e "${GREEN}[OK]${NC} Token $id revoked"
      ;;

    ""|help|--help|-h)
      echo "Usage: mc-ctl mcp-token <create|list|revoke>"
      echo ""
      echo "  create --client <name> [--expires-in-days N]   Generate a new read-only bearer token"
      echo "  list                                            List all tokens (active + revoked + expired)"
      echo "  revoke <id>                                     Revoke a token by id"
      ;;

    *)
      echo -e "${RED}Unknown mcp-token subcommand:${NC} $subcmd"
      echo "  Usage: mc-ctl mcp-token [create|list|revoke]"
      exit 1
      ;;
  esac
}

