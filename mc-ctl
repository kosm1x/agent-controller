cmd_memory() {
  need_db
  echo -e "${BOLD}=== Memory Status ===${NC}"
  echo ""

  local conv_count bank_count latest
  conv_count=$(sql_raw "SELECT COUNT(*) FROM conversations;" 2>/dev/null || echo "0")
  bank_count=$(sql_raw "SELECT COUNT(DISTINCT bank) FROM conversations;" 2>/dev/null || echo "0")
  latest=$(sql_raw "SELECT MAX(created_at) FROM conversations;" 2>/dev/null || echo "none")

  echo -e "  Backend:        SQLite (conversations table)"
  echo -e "  Conversations:  ${conv_count}"
  echo -e "  Banks:          ${bank_count}"
  echo -e "  Latest:         ${latest}"

  # Hindsight
  echo ""
  if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "$HINDSIGHT_CONTAINER"; then
    if curl -sf --max-time 3 "${HINDSIGHT_URL}/health" >/dev/null 2>&1; then
      echo -e "  Hindsight:      ${GREEN}healthy${NC} (${HINDSIGHT_URL})"
    else
      echo -e "  Hindsight:      ${YELLOW}container up, API unhealthy${NC}"
    fi
  else
    echo -e "  Hindsight:      ${DIM}not running${NC}"
  fi
  echo ""
}

# ---------------------------------------------------------------------------
# Hindsight
# ---------------------------------------------------------------------------

cmd_recall_utility() {
  need_db
  local since_arg="${1:-24h}"
  local since_clause

  # Validate prefix is purely numeric BEFORE building any SQL clause —
  # case patterns alone only match the suffix, so e.g. "1; DROP h" matches
  # *h. Audit W1 (qa-auditor 2026-04-29) caught this injection vector.
  local prefix="${since_arg%[hdm]}"
  if [[ "$prefix" =~ ^[0-9]+$ ]]; then
    case "$since_arg" in
      *h) since_clause="datetime('now','-${prefix} hours')" ;;
      *d) since_clause="datetime('now','-${prefix} days')" ;;
      *m) since_clause="datetime('now','-${prefix} minutes')" ;;
      *)  since_clause="datetime('now','-24 hours')" ;;
    esac
  else
    echo -e "${YELLOW}Invalid since arg '${since_arg}', falling back to 24h${NC}"
    since_clause="datetime('now','-24 hours')"
    since_arg="24h"
  fi

  echo -e "${BOLD}=== Recall Utility (last ${since_arg}) ===${NC}"
  echo ""

  local total marked unmarked
  total=$(sql_raw "SELECT COUNT(*) FROM recall_audit WHERE created_at >= ${since_clause};" 2>/dev/null || echo "0")
  marked=$(sql_raw "SELECT COUNT(*) FROM recall_audit WHERE created_at >= ${since_clause} AND was_used IS NOT NULL;" 2>/dev/null || echo "0")
  unmarked=$(sql_raw "SELECT COUNT(*) FROM recall_audit WHERE created_at >= ${since_clause} AND was_used IS NULL;" 2>/dev/null || echo "0")

  echo -e "  Total recalls:    ${total}"
  echo -e "  Matched (marked): ${marked}"
  echo -e "  Pending (NULL):   ${unmarked}"
  echo ""

  if [ "${marked:-0}" -gt 0 ]; then
    echo -e "${BOLD}Utility by source:${NC}"
    sql_raw "SELECT source,
                    COUNT(*) AS n,
                    SUM(CASE WHEN was_used = 1 THEN 1 ELSE 0 END) AS used,
                    ROUND(100.0 * SUM(CASE WHEN was_used = 1 THEN 1 ELSE 0 END) / COUNT(*), 1) AS pct_used,
                    SUM(COALESCE(excluded_count, 0)) AS dropped,
                    ROUND(AVG(latency_ms), 0) AS avg_ms
             FROM recall_audit
             WHERE created_at >= ${since_clause} AND was_used IS NOT NULL
             GROUP BY source
             ORDER BY n DESC;" 2>/dev/null \
      | awk -F'|' 'BEGIN { printf "  %-18s %6s %6s %8s %8s %8s\n", "source", "n", "used", "pct%", "dropped", "avg_ms" }
                   { printf "  %-18s %6s %6s %8s %8s %8s\n", $1, $2, $3, $4, $5, $6 }'
    echo ""

    echo -e "${BOLD}Utility by bank:${NC}"
    sql_raw "SELECT bank,
                    COUNT(*) AS n,
                    SUM(CASE WHEN was_used = 1 THEN 1 ELSE 0 END) AS used,
                    ROUND(100.0 * SUM(CASE WHEN was_used = 1 THEN 1 ELSE 0 END) / COUNT(*), 1) AS pct_used
             FROM recall_audit
             WHERE created_at >= ${since_clause} AND was_used IS NOT NULL
             GROUP BY bank
             ORDER BY n DESC;" 2>/dev/null \
      | awk -F'|' 'BEGIN { printf "  %-18s %6s %6s %8s\n", "bank", "n", "used", "pct%" }
                   { printf "  %-18s %6s %6s %8s\n", $1, $2, $3, $4 }'
    echo ""

    # Match-type breakdown — Ship B (2026-04-30): dual-signal matcher.
    # match_type ∈ {verbatim, token-overlap, none}. Distinguishes "agent
    # quoted recall verbatim" from "agent paraphrased recall content" from
    # "no signal of use" — informs the strategic Hindsight decision.
    echo -e "${BOLD}Utility by match type:${NC}"
    sql_raw "SELECT COALESCE(match_type, '(legacy)') AS mt,
                    COUNT(*) AS n,
                    ROUND(AVG(overlap_score), 2) AS avg_score
             FROM recall_audit
             WHERE created_at >= ${since_clause} AND was_used IS NOT NULL
             GROUP BY match_type
             ORDER BY n DESC;" 2>/dev/null \
      | awk -F'|' 'BEGIN { printf "  %-18s %6s %10s\n", "match_type", "n", "avg_score" }
                   { printf "  %-18s %6s %10s\n", $1, $2, $3 }'
    echo ""

    # Outcome distribution (queue #7 part 2 + #8): aggregates per-recall
    # outcome_breakdown JSON to surface what fraction of recalled material
    # was failure narrative. Drives the Hindsight A/B/C decision when
    # combined with the source/bank/match-type tables above.
    local outcome_rows
    outcome_rows=$(sql_raw "SELECT COUNT(*) FROM recall_audit
                            WHERE created_at >= ${since_clause}
                              AND outcome_breakdown IS NOT NULL;" 2>/dev/null || echo "0")
    if [[ "${outcome_rows:-0}" -gt 0 ]]; then
      echo -e "${BOLD}Outcome distribution (per-recall avg):${NC}"
      sql_raw "SELECT
                 ROUND(AVG(json_extract(outcome_breakdown, '\$.success')), 2) AS success_per_call,
                 ROUND(AVG(json_extract(outcome_breakdown, '\$.concerns')), 2) AS concerns_per_call,
                 ROUND(AVG(json_extract(outcome_breakdown, '\$.failed')), 2) AS failed_per_call,
                 ROUND(AVG(json_extract(outcome_breakdown, '\$.unknown')), 2) AS unknown_per_call,
                 COUNT(*) AS rows_with_breakdown
               FROM recall_audit
               WHERE created_at >= ${since_clause}
                 AND outcome_breakdown IS NOT NULL;" 2>/dev/null \
        | awk -F'|' 'BEGIN { printf "  %-12s %-12s %-12s %-12s %s\n", "success/call", "concerns/call", "failed/call", "unknown/call", "n" }
                     { printf "  %-12s %-12s %-12s %-12s %s\n", $1, $2, $3, $4, $5 }'
      echo ""
    fi
  else
    echo -e "  ${DIM}No matched rows yet — wait for turn-end matches to accumulate.${NC}"
    echo ""
  fi
}

cmd_outcome_distribution() {
  # Queue #7 part 3 (2026-05-07) — standalone view of outcome:* tag
  # distribution across both retains (conversations.tags) and recalls
  # (recall_audit.outcome_breakdown). Drives the Hindsight A/B/C decision
  # together with mc-ctl recall-utility.
  # Usage: mc-ctl outcome-distribution [WINDOW]   default 7d
  need_db
  local since_arg="${1:-7d}"
  local since_clause

  local prefix="${since_arg%[hdm]}"
  if [[ "$prefix" =~ ^[0-9]+$ ]]; then
    case "$since_arg" in
      *h) since_clause="datetime('now','-${prefix} hours')" ;;
      *d) since_clause="datetime('now','-${prefix} days')" ;;
      *m) since_clause="datetime('now','-${prefix} minutes')" ;;
      *)  since_clause="datetime('now','-7 days')" ;;
    esac
  else
    echo -e "${YELLOW}Invalid window '${since_arg}', falling back to 7d${NC}"
    since_clause="datetime('now','-7 days')"
    since_arg="7d"
  fi

  echo -e "${BOLD}=== Outcome Distribution (last ${since_arg}) ===${NC}"
  echo ""

  echo -e "${BOLD}Retains (conversations.tags):${NC}"
  # W6 audit fix (2026-05-07): exclusive case branches so a hypothetical
  # multi-outcome retain (not produced today, but possible) doesn't
  # double-count. First outcome wins, matching the recall-side and
  # recordRetainOutcome semantics.
  # Round-2 audit note: SQL priority is FIXED (success > concerns > failed
  # > unknown); JS recordRetainOutcome priority is ARRAY-ORDER first match.
  # These can diverge if a future producer ever emits multiple outcome:* tags
  # on a single retain (`["outcome:concerns","outcome:success"]` →
  # JS counts concerns, SQL counts success). Today's outcome-tag.ts emits
  # exactly one tag per retain so no live divergence. If multi-outcome
  # producers ever arrive, decide one priority and align both.
  sql_raw "
    SELECT
      bank,
      SUM(CASE WHEN tags LIKE '%outcome:success%' THEN 1 ELSE 0 END) AS success,
      SUM(CASE WHEN tags LIKE '%outcome:concerns%' AND tags NOT LIKE '%outcome:success%' THEN 1 ELSE 0 END) AS concerns,
      SUM(CASE WHEN tags LIKE '%outcome:failed%' AND tags NOT LIKE '%outcome:success%' AND tags NOT LIKE '%outcome:concerns%' THEN 1 ELSE 0 END) AS failed,
      SUM(CASE WHEN (tags NOT LIKE '%outcome:success%' AND tags NOT LIKE '%outcome:concerns%' AND tags NOT LIKE '%outcome:failed%') THEN 1 ELSE 0 END) AS unknown,
      COUNT(*) AS total
    FROM conversations
    WHERE created_at >= ${since_clause}
    GROUP BY bank
    ORDER BY total DESC;
  " 2>/dev/null \
    | awk -F'|' 'BEGIN { printf "  %-18s %8s %8s %8s %8s %8s\n", "bank", "success", "concerns", "failed", "unknown", "total" }
                 { printf "  %-18s %8s %8s %8s %8s %8s\n", $1, $2, $3, $4, $5, $6 }'
  echo ""

  echo -e "${BOLD}Recalls (recall_audit.outcome_breakdown JSON):${NC}"
  local rows
  rows=$(sql_raw "SELECT COUNT(*) FROM recall_audit
                  WHERE created_at >= ${since_clause}
                    AND outcome_breakdown IS NOT NULL;" 2>/dev/null || echo "0")
  if [[ "${rows:-0}" -eq 0 ]]; then
    echo -e "  ${DIM}No outcome_breakdown rows yet (column added 2026-05-07).${NC}"
    echo ""
  else
    sql_raw "
      SELECT
        bank,
        ROUND(SUM(json_extract(outcome_breakdown, '\$.success')), 0) AS success,
        ROUND(SUM(json_extract(outcome_breakdown, '\$.concerns')), 0) AS concerns,
        ROUND(SUM(json_extract(outcome_breakdown, '\$.failed')), 0) AS failed,
        ROUND(SUM(json_extract(outcome_breakdown, '\$.unknown')), 0) AS unknown,
        COUNT(*) AS calls
      FROM recall_audit
      WHERE created_at >= ${since_clause}
        AND outcome_breakdown IS NOT NULL
      GROUP BY bank
      ORDER BY calls DESC;
    " 2>/dev/null \
      | awk -F'|' 'BEGIN { printf "  %-18s %8s %8s %8s %8s %8s\n", "bank", "success", "concerns", "failed", "unknown", "calls" }
                   { printf "  %-18s %8s %8s %8s %8s %8s\n", $1, $2, $3, $4, $5, $6 }'
    echo ""
  fi

  # Headline ratio: concerns share of retains over the window. Drives the
  # RetainOutcomeConcerns alert.
  local concerns_pct
  concerns_pct=$(sql_raw "
    SELECT ROUND(
      100.0 * SUM(CASE WHEN tags LIKE '%outcome:concerns%' THEN 1 ELSE 0 END)
            / NULLIF(COUNT(*), 0),
      1)
    FROM conversations
    WHERE created_at >= ${since_clause};
  " 2>/dev/null || echo "0")
  echo -e "${BOLD}Concerns ratio (all banks):${NC} ${concerns_pct:-0}%"
  echo "  Threshold: 25% triggers RetainOutcomeConcerns alert (24h sustain)."
  echo ""
}

cmd_recall_compare() {
  # Ship C (2026-04-30) — side-by-side replay of recent recall_audit
  # queries against both Hindsight and SQLite for manual quality eval.
  # Used to inform the 2026-05-13 HARDEN/DEMOTE/REPLACE decision.
  #
  # Usage: mc-ctl recall-compare [N] [SINCE]
  #   N     = number of unique queries to replay (default 5, max 50)
  #   SINCE = window for sourcing queries (default 24h, accepts Nh/Nd/Nm)
  need_db
  local n="${1:-5}"
  local since_arg="${2:-24h}"

  # Validate N is small positive integer. Cap raised from 20 → 50 on 2026-05-03
  # so the H/D/R-decision A/B (target 30) doesn't silently truncate.
  if ! [[ "$n" =~ ^[0-9]+$ ]] || [ "$n" -lt 1 ] || [ "$n" -gt 50 ]; then
    echo -e "${YELLOW}Invalid N '${n}', falling back to 5${NC}"
    n=5
  fi

  # Reuse the same prefix-validation pattern as cmd_recall_utility (W1)
  local prefix="${since_arg%[hdm]}"
  local since_clause
  if [[ "$prefix" =~ ^[0-9]+$ ]]; then
    case "$since_arg" in
      *h) since_clause="datetime('now','-${prefix} hours')" ;;
      *d) since_clause="datetime('now','-${prefix} days')" ;;
      *m) since_clause="datetime('now','-${prefix} minutes')" ;;
      *)  since_clause="datetime('now','-24 hours')" ;;
    esac
  else
    echo -e "${YELLOW}Invalid since arg '${since_arg}', falling back to 24h${NC}"
    since_clause="datetime('now','-24 hours')"
    since_arg="24h"
  fi

  echo -e "${BOLD}=== Recall Compare — replay ${n} queries (last ${since_arg}) ===${NC}"
  echo ""

  # Pull N unique recent queries with their bank. ROWID-ordered so we get
  # newest unique tuples first; reservoir-sampling would be overkill.
  # Strip newlines + carriage returns from query text so the bash `read`
  # loop below treats one DB row as one logical record (qa-auditor W2 —
  # operator/Telegram-supplied recall queries can contain `\n`).
  local rows
  rows=$(sql_raw "SELECT bank || '|' ||
                         replace(replace(query, char(10), ' '), char(13), ' ')
                  FROM recall_audit
                  WHERE created_at >= ${since_clause} AND length(query) > 0
                  GROUP BY bank, query
                  ORDER BY MAX(created_at) DESC
                  LIMIT ${n};" 2>/dev/null)

  if [ -z "$rows" ]; then
    echo -e "  ${DIM}No recall_audit rows in window. Try a wider --since or wait for traffic.${NC}"
    return 0
  fi

  local idx=0
  while IFS='|' read -r bank query; do
    [ -z "$query" ] && continue
    idx=$((idx + 1))
    echo -e "${BOLD}[${idx}/${n}] bank=${bank}${NC}"
    echo -e "  query: ${CYAN}$(echo "$query" | head -c 200)${NC}"
    echo ""

    # POST to admin endpoint. jq builds the body so embedded quotes /
    # special chars in the recall query don't break the curl command line.
    local body
    body=$(jq -n --arg q "$query" --arg b "$bank" '{query:$q, bank:$b, topN:3}')
    local response
    response=$(api POST /api/admin/recall-compare -d "$body" 2>&1) || {
      echo -e "  ${RED}endpoint failed: ${response}${NC}"
      echo ""
      continue
    }

    # Format both sides side-by-side (sequential, terminal-friendly)
    local hs_err sql_err hs_lat sql_lat hs_count sql_count
    hs_err=$(echo "$response" | jq -r '.hindsight.error // empty')
    sql_err=$(echo "$response" | jq -r '.sqlite.error // empty')
    hs_lat=$(echo "$response" | jq -r '.hindsight.latencyMs // 0')
    sql_lat=$(echo "$response" | jq -r '.sqlite.latencyMs // 0')
    hs_count=$(echo "$response" | jq -r '.hindsight.totalCount // 0')
    sql_count=$(echo "$response" | jq -r '.sqlite.totalCount // 0')

    if [ -n "$hs_err" ]; then
      echo -e "  ${BOLD}HINDSIGHT${NC} ${RED}error${NC} (${hs_lat}ms): ${hs_err}"
    else
      echo -e "  ${BOLD}HINDSIGHT${NC} (${hs_lat}ms, total=${hs_count}, top-3):"
      echo "$response" | jq -r '.hindsight.results[] | "    • " + (.content | gsub("\n"; " ") | .[:160])'
    fi
    echo ""
    if [ -n "$sql_err" ]; then
      echo -e "  ${BOLD}SQLITE${NC}    ${RED}error${NC} (${sql_lat}ms): ${sql_err}"
    else
      echo -e "  ${BOLD}SQLITE${NC}    (${sql_lat}ms, total=${sql_count}, top-3):"
      echo "$response" | jq -r '.sqlite.results[] | "    • " + (.content | gsub("\n"; " ") | .[:160])'
    fi
    echo ""
    echo -e "  ${DIM}Verdict (note manually):  HINDSIGHT_BETTER  EQUAL  SQLITE_BETTER${NC}"
    echo "  ────────────────────────────────────────────────────────────────"
    echo ""
  done <<< "$rows"
}

cmd_drift() {
  # Exit codes (qa-auditor W1, 2026-04-29):
  #   0 = no drift (all invariants hold)
  #   1 = drift detected, none critical (warning + info only)
  #   2 = critical drift (cron-style alerters should treat as urgent)
  # Usage in cron: `mc-ctl drift > /dev/null || alert` covers any drift;
  # `mc-ctl drift > /dev/null; [ $? -ge 2 ] && alert` covers critical-only.
  echo -e "${BOLD}=== Config Drift (V8 substrate S3) ===${NC}"
  echo ""

  local response
  response=$(api GET /api/admin/drift 2>&1) || {
    echo -e "${RED}Failed to query drift endpoint.${NC}"
    echo "  $response"
    return 1
  }

  local total critical warning info
  total=$(echo "$response" | jq -r '.summary.total // 0')
  critical=$(echo "$response" | jq -r '.summary.critical // 0')
  warning=$(echo "$response" | jq -r '.summary.warning // 0')
  info=$(echo "$response" | jq -r '.summary.info // 0')

  if [ "${total:-0}" -eq 0 ]; then
    echo -e "  ${GREEN}No drift detected.${NC} All declared invariants hold."
    echo ""
    return 0
  fi

  echo -e "  Drifts: ${total} (${RED}${critical} critical${NC}, ${YELLOW}${warning} warning${NC}, ${DIM}${info} info${NC})"
  echo ""

  echo "$response" | jq -r '.drifts[] |
    "  [\(.severity | ascii_upcase)] \(.key)\n      desc:     \(.description)\n      expected: \(.expected)\n      actual:   \(.actual // "(unset)")\n      status:   \(.status)\n"'

  # Exit non-zero on critical drift so cron-style pipelines can alert
  if [ "${critical:-0}" -gt 0 ]; then
    return 2
  fi
  return 1
}

cmd_audit_claim() {
  # V8 substrate S2 — self-audit before reporting.
  # Stratify-and-cross-check a metric BEFORE quoting the headline. Born
  # from the 2026-05-03 trilogy incident: aggregate "22.2% utility" hid
  # a complete collapse on the operator's primary bank.
  #
  # Usage: mc-ctl audit-claim METRIC [--window=24h] [--stratify-by=COL] [--baseline=N] [--min-n=N]
  #   METRIC      = utility | cache-hit | latency | cost
  #   --window    = Nh|Nd|Nm (default 24h)
  #   --stratify-by = bank|source|match_type|agent_type|model (metric-dependent)
  #   --baseline  = numeric reference value to compare headline against
  #   --min-n     = minimum sample size to accept verification (default 30)
  #
  # Exit codes:
  #   0 = verified (no warnings, sample sufficient)
  #   1 = warnings present (small-n, dominance, divergence, baseline)
  #   2 = invalid input or fetch error (build/deploy required if module missing)
  local metric="${1:-}"
  shift 2>/dev/null || true

  if [ -z "$metric" ]; then
    echo -e "${RED}Error:${NC} metric required"
    echo "  Usage: mc-ctl audit-claim METRIC [--window=24h] [--stratify-by=COL] [--baseline=N] [--min-n=N]"
    echo "  Metrics: utility | cache-hit | latency | cost"
    return 2
  fi

  local window="24h" stratify="" baseline="" min_n=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --window=*)        window="${1#*=}" ;;
      --stratify-by=*)   stratify="${1#*=}" ;;
      --baseline=*)      baseline="${1#*=}" ;;
      --min-n=*)         min_n="${1#*=}" ;;
      *)
        echo -e "${RED}Unknown flag:${NC} $1"
        return 2
        ;;
    esac
    shift
  done

  # Validate metric (poka-yoke before shelling to node)
  case "$metric" in
    utility|cache-hit|latency|cost) ;;
    *) echo -e "${RED}Unknown metric '${metric}'.${NC} Use: utility | cache-hit | latency | cost"; return 2 ;;
  esac

  # Build JSON request — jq handles quoting + null-elision.
  local req
  req=$(jq -n \
    --arg metric "$metric" \
    --arg window "$window" \
    --arg stratify "$stratify" \
    --arg baseline "$baseline" \
    --arg min_n "$min_n" \
    '{
       metric: $metric,
       window: $window,
       stratifyBy: (if $stratify == "" then null else $stratify end),
       baseline:   (if $baseline == "" then null else ($baseline | tonumber) end),
       minN:       (if $min_n == "" then null else ($min_n | tonumber) end)
     } | with_entries(select(.value != null))')

  local cli_path="${PROJECT_DIR}/dist/audit/cli.js"
  if [ ! -f "$cli_path" ]; then
    echo -e "${RED}Error:${NC} ${cli_path} missing — run ./scripts/deploy.sh"
    return 2
  fi

  echo -e "${BOLD}=== Self-Audit (V8 substrate S2) ===${NC}"
  echo ""
  # cli.js initializes the DB singleton against ${PROJECT_DIR}/data/mc.db
  # (overridable via MC_DB_PATH) and exits with verdict-coded status.
  MC_DB_PATH="${DB_PATH}" node "${cli_path}" "${req}"
  local rc=$?
  echo ""
  case $rc in
    0) echo -e "${GREEN}[VERIFIED]${NC} Headline is safe to report." ;;
    1) echo -e "${YELLOW}[WARNINGS]${NC} Do NOT report headline as-is — address notes above." ;;
    2) echo -e "${YELLOW}[INSUFFICIENT N]${NC} Sample too small for the requested minN." ;;
    3) echo -e "${RED}[MODULE LOAD ERROR]${NC} See stderr above." ;;
    *) echo -e "${RED}[UNKNOWN EXIT $rc]${NC}" ;;
  esac
  return $rc
}

cmd_skill_health() {
  # v7.7 Spine 3 Phase 2 Bundle 2 — operator-facing skill catalog health.
  # Reports: certification state, last test run, recent pass/fail counts,
  # anti-list status (consecutive_failures), critic override count.
  #
  # Usage: mc-ctl skill-health [--window=7d] [--name=NAME] [--include-inactive]
  #   --window           = freshness window for "recent passes/fails" (default 7d)
  #   --name             = filter to one skill by name
  #   --include-inactive = include active=0 rows in output

  local window="7d" name_filter="" include_inactive=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --window=*)          window="${1#*=}" ;;
      --name=*)            name_filter="${1#*=}" ;;
      --include-inactive)  include_inactive=1 ;;
      *)
        echo -e "${RED}Unknown flag:${NC} $1"
        echo "  Usage: mc-ctl skill-health [--window=7d] [--name=NAME] [--include-inactive]"
        return 2
        ;;
    esac
    shift
  done

  # R1-C1 fold: validate --name= against the same regex skill names must
  # already match (frontmatter.ts NAME_RE: lowercase + hyphens). Prevents
  # SQL injection through the HEREDOC's literal interpolation below — the
  # sqlite3 CLI doesn't bind parameters via HEREDOC, so we sanitize at
  # the entry boundary instead.
  if [ -n "$name_filter" ]; then
    # R2-W1 verify-then-revert: the 67 legacy DB skills (pre-Phase-1) have
    # underscores in names (e.g. `health_check`, `commit_push_y_ejecutar_shell`)
    # because they predate the frontmatter NAME_RE enforcement. The bash
    # filter is INTENTIONALLY a superset of frontmatter NAME_RE so the CLI
    # can inspect legacy skills. The character class is a safe sanitizer
    # against SQL injection regardless of which subset matches in practice.
    if [[ ! "$name_filter" =~ ^[a-z0-9][a-z0-9_-]{0,62}[a-z0-9]$ ]]; then
      echo -e "${RED}Invalid --name:${NC} must be lowercase + hyphens/underscores (2-64 chars)"
      return 2
    fi
  fi

  # SQLite datetime modifier — accept Nh|Nd|Nm and translate.
  local sqlite_window
  case "$window" in
    *h) sqlite_window="-$((${window%h})) hours" ;;
    *d) sqlite_window="-${window%d} days" ;;
    *m) sqlite_window="-${window%m} months" ;;
    *)
      echo -e "${RED}Invalid --window:${NC} $window (use Nh|Nd|Nm, e.g. 7d)"
      return 2
      ;;
  esac

  local where="WHERE 1=1"
  [ $include_inactive -eq 0 ] && where="$where AND s.active = 1"
  [ -n "$name_filter" ] && where="$where AND s.name = '$name_filter'"

  echo -e "${BOLD}=== Skill Health (window: ${window}) ===${NC}"
  echo ""

  # Joined query: per-skill aggregate of skill_test_runs in the window.
  # COALESCE handles skills with zero test runs (never certified).
  # `-column -header` formats with auto-width; widths capped via substr.
  sqlite3 -column -header "$DB_PATH" <<SQL
SELECT
  substr(s.name, 1, 32) AS name,
  s.version AS version,
  CASE WHEN s.is_certified = 1 THEN 'YES' ELSE 'no' END AS certified,
  COALESCE(stats.recent_total, 0) AS recent,
  COALESCE(stats.pass_count, 0) AS passes,
  COALESCE(stats.fail_count, 0) AS fails,
  s.consecutive_failures AS failstrk
FROM skills s
LEFT JOIN (
  SELECT
    skill_id,
    COUNT(*) AS recent_total,
    SUM(CASE WHEN result = 'pass' THEN 1 ELSE 0 END) AS pass_count,
    SUM(CASE WHEN result <> 'pass' THEN 1 ELSE 0 END) AS fail_count
  FROM skill_test_runs
  WHERE ran_at >= datetime('now', '$sqlite_window')
  GROUP BY skill_id
) stats ON stats.skill_id = s.skill_id
$where
ORDER BY s.is_certified DESC, COALESCE(stats.fail_count, 0) DESC, s.name ASC
LIMIT 200;
SQL

  echo ""

  # Override (operator-bypassed) summary
  local overrides
  overrides=$(sqlite3 "$DB_PATH" <<SQL
SELECT COUNT(*) FROM skill_versions
WHERE critic_verdict = 'fail_returned_anyway'
  AND created_at >= datetime('now', '$sqlite_window');
SQL
)
  if [ "${overrides:-0}" -gt 0 ]; then
    echo -e "${YELLOW}⚠ ${overrides} operator override(s) within ${window}:${NC}"
    sqlite3 "$DB_PATH" <<SQL
SELECT
  '  - ' || s.name || ' v' || v.version ||
  ' (' || substr(v.critic_critique, 1, 80) || ')' AS line
FROM skill_versions v
JOIN skills s ON s.skill_id = v.skill_id
WHERE v.critic_verdict = 'fail_returned_anyway'
  AND v.created_at >= datetime('now', '$sqlite_window')
ORDER BY v.created_at DESC
LIMIT 10;
SQL
    echo ""
  fi

  # Activation gate snapshot (spec §14).
  # R1-W3 fold: spec §14 requires `recent_passes >= test_count` per skill
  # within 7d, not just the is_certified flag. Tighten the count to skills
  # that also have at least one passing test run in the last 7 days — if
  # sweep is paused or fails, stale certifications stop counting.
  local certified_count
  certified_count=$(sqlite3 "$DB_PATH" \
    "SELECT COUNT(*) FROM skills s
     WHERE s.is_certified = 1 AND s.active = 1
       AND EXISTS (
         SELECT 1 FROM skill_test_runs r
         WHERE r.skill_id = s.skill_id
           AND r.result = 'pass'
           AND r.ran_at >= datetime('now','-7 days')
       );")
  echo -e "${BOLD}Activation gate:${NC} ${certified_count} of ≥5 certified active skills (spec §14)"
  if [ "${certified_count:-0}" -ge 5 ]; then
    echo -e "  ${GREEN}✓ Activation gate met${NC}"
  else
    echo -e "  ${YELLOW}△ Below activation threshold${NC} ($(( 5 - certified_count )) more needed)"
  fi
}

